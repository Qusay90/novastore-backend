PORT=5000
NODE_ENV=development

# Local Postgres
DATABASE_URL=postgres://user:password@localhost:5432/novastore
DB_SSL=false

# Supabase on IPv4-only networks or Windows
# Direct hostlar (db.<project-ref>.supabase.co) bazi ortamlarda yalnizca IPv6 doner.
# Bu durumda Session Pooler kullan:
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
# SUPABASE_USE_POOLER=true
# SUPABASE_REGION=eu-west-1
# SUPABASE_POOLER_MODE=session
# DB_USER=postgres.YOUR_PROJECT_REF
# DB_PORT=5432
# DB_SSL=true
# Alternatif olarak SUPABASE_POOLER_HOST=aws-0-eu-west-1.pooler.supabase.com verebilirsin.

JWT_SECRET=change_me
CLIENT_ORIGIN=http://localhost:5000
APP_BASE_URL=http://localhost:5000
# Production or custom domain example:
# CLIENT_ORIGIN=https://novastore.tr,https://www.novastore.tr
# APP_BASE_URL=https://novastore.tr
# MAIL_FROM=NovaStore Destek <destek@novastore.tr>

IYZICO_WEBHOOK_SECRET=
IYZICO_MOCK_MODE=true

FREE_SHIPPING_THRESHOLD=1500
DEFAULT_SHIPPING_FEE=49.9
DEFAULT_SHIPMENT_PROVIDER=Yurtici Kargo

HAVALE_ACCOUNT_NAME=NovaStore Elektronik
HAVALE_IBAN=TR00 0000 0000 0000 0000 0000 00

EMAIL_USER=
EMAIL_PASS=
MAIL_FROM=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
